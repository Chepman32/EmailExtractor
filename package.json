{
  "name": "EmailExtractor",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ci": "yarn lint && yarn typecheck && yarn test:unit && yarn test:integration && yarn test:component",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest --cacheDirectory=.jest-cache",
    "test:component": "jest --runInBand --cacheDirectory=.jest-cache --testPathPattern=component.test",
    "test:e2e:ios": "detox test -c ios.sim.debug",
    "test:integration": "jest --runInBand --cacheDirectory=.jest-cache --testPathPattern=int.test",
    "test:unit": "jest --runInBand --cacheDirectory=.jest-cache --testPathPattern=unit.test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native/new-app-screen": "0.84.1",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-document-picker": "^9.3.1",
    "react-native-fs": "^2.20.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-vector-icons": "^10.3.0",
    "react-native-zip-archive": "^7.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "detox": "^20.47.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 20.19.0"
  },
